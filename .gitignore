# Generated dist artifacts (stele.html, executables, site build)
# dist/ and build/ already covered above; these are extra reminders:
# dist/stele.html           — generated by tools/build_single_html.py
# dist/site/                — generated by tools/build_pyodide_site.py
# dist/SteleStudio*         — generated by packaging/build_app.py

# Local Pyodide runtime assets (for --pyodide-local offline experiments)
# Users may unpack Pyodide here; do not commit runtime binaries.
pyodide-local/
pyodide_local/
local_pyodide/

# Generated corpora (only bench/generated/sample/ is committed)
bench/generated/*/
!bench/generated/sample/
!bench/generated/sample/**

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
